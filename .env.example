# Client-safe Expo variables only.
# Never put SUPABASE_SERVICE_ROLE_KEY or any admin/server secret in Expo env files.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Recommended for the Codex/Vercel review build so judges land in a seeded local-first demo.
# Web also defaults to demo mode when unset. Set to false only when web should require real Supabase auth.
EXPO_PUBLIC_WEB_DEMO_MODE=true
